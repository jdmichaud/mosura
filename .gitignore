# mosura build artifacts (regenerated by scripts/setup-oracle.sh)
/build/

# Rust
/target/
**/*.rs.bk
Cargo.lock.bak

# local throwaway grounding tools (dump the IR/C/scope of a fixture); never committed.
# The trace runner examples/trace.rs IS tracked (scripts/trace-diff.sh depends on it).
/crates/mosura/examples/dump*.rs

# offline capture tool (binary built by setup-oracle.sh; source is tracked)
/oracle/capture
# rule-application trace tool (binary built by setup-oracle.sh; source is tracked)
/oracle/capture_trace
/oracle/*.o

# Generated test goldens are committed deliberately; nothing here.
# NOTE: the standalone oracle tools and compiled *.sla live under ../ghidra and
# are ignored by Ghidra's own .gitignore — they are not part of this repo.
